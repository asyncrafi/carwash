# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.local

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=carwash
DB_USER=carwash
DB_PASSWORD=carwash_pass
DB_HOST=db
DB_PORT=5432

# Redis & Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (dev: console, prod: SMTP or SendGrid/Mailgun)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@carwash.app

# Anymail (optional — set only one provider)
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Superuser (auto-created on docker first run)
DJANGO_SUPERUSER_PHONE=+33600000000
DJANGO_SUPERUSER_PASSWORD=admin123
